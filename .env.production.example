# ============================================================
# CivicLens — Production Environment Variables
# Instance: OCI ARM64 (12 GB RAM / 2 OCPU)
# Domain: civiclens.space
# ============================================================
# Copy this file to .env and fill in values.
# NEVER commit .env — it contains secrets!
# chmod 600 .env
# ============================================================

# ---- Application ----
APP_NAME=CivicLens
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
CITY_CODE=MC
ORG_NAME=Municipal Corporation
ORG_SHORT_NAME=MC
ORG_SUPPORT_EMAIL=support@civiclens.space
REPORT_NUMBER_PREFIX=CL
APP_BASE_URL=https://civiclens.space

# ---- Database (PostgreSQL + PostGIS) ----
DB_NAME=civiclens_db
DB_USER=civiclens_user
DB_PASSWORD=CivicLens_DB_2026_!
# DATABASE_URL is constructed in docker-compose.yml — do not set here
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# ---- Redis ----
REDIS_PASSWORD=CivicLens_Redis_Sec_!
# REDIS_URL is constructed in docker-compose.yml — do not set here

# ---- Security ----
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=79c546c1fbab97fb1be3a4baebdc85f88d893adad883ea579c44484c0fe21083a26a13e877e17155ca5ffe546ccb45b266ea41ddf7bd70e09ae2d53ad8db342b
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_TOKEN_EXPIRE_HOURS=8

# ---- MinIO Object Storage ----
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_must_be_8_chars_min
MINIO_BUCKET=civiclens-media
MINIO_USE_SSL=false

# ---- CORS ----
CORS_ORIGINS=https://civiclens.space,https://admin.civiclens.space

# ---- Security Settings ----
# Caddy handles TLS termination, so HTTPS_ONLY must be false
# to avoid redirect loops within the Docker network
HTTPS_ONLY=false
SECURE_COOKIES=true
SECURITY_HEADERS_ENABLED=true

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900

# ---- Audit Logging ----
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# ---- Error Tracking (Sentry — optional) ----
SENTRY_DSN=

# ---- Email (SMTP — optional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@civiclens.space
SMTP_USE_TLS=true

# ---- SMS (for OTP — optional) ----
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# ---- Password Policy ----
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ---- 2FA ----
TWO_FA_ENABLED=true
TWO_FA_REQUIRED_FOR_ROLES=super_admin
