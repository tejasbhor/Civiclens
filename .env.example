# ============================================================
# CivicLens — Local Development Environment Variables
# ============================================================
# Copy this file to .env and update values as needed.
# For production, see .env.production.example instead.
# ============================================================

# ---- Application ----
APP_NAME=CivicLens
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
CITY_CODE=MC
ORG_NAME=Municipal Corporation
ORG_SHORT_NAME=MC
ORG_SUPPORT_EMAIL=support@example.com
REPORT_NUMBER_PREFIX=CL

# ---- Database (Local PostgreSQL + PostGIS) ----
DB_USER=civiclens_user
DB_PASSWORD=password123
DB_NAME=civiclens_db
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://civiclens_user:password123@localhost:5432/civiclens_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# ---- Redis (local or via Docker) ----
REDIS_PASSWORD=devredispass
# Format: redis://:password@host:port/db
REDIS_URL=redis://:devredispass@localhost:6379/0

# ---- Security ----
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- MinIO Object Storage (local or via Docker) ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=civiclens-media
MINIO_USE_SSL=false

# ---- CORS (allow all dev servers) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8080

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=false

# ---- Audit Logging ----
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
