{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "NODE_ENV": "development",
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.civiclens.space/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://api.civiclens.space/api/v1/ws",
        "EXPO_PUBLIC_MINIO_URL": "https://api.civiclens.space",
        "EXPO_PUBLIC_ENABLE_DEMO_OTP": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.civiclens.space/api/v1",
        "EXPO_PUBLIC_WS_URL": "wss://api.civiclens.space/api/v1/ws",
        "EXPO_PUBLIC_MINIO_URL": "https://api.civiclens.space",
        "EXPO_PUBLIC_ENABLE_DEMO_OTP": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}