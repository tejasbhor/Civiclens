# Environment: development, staging, or production
EXPO_PUBLIC_ENV=development

# API Configuration
# Local: http://<YOUR_LOCAL_IP>:8000/api/v1 (Auto-detected if blank in Dev)
# Production: https://api.civiclens.space/api/v1
EXPO_PUBLIC_API_BASE_URL=

# WebSocket (Required for real-time notifications)
# Local: ws://<YOUR_LOCAL_IP>:8000/api/v1/ws
# Production: wss://api.civiclens.space/api/v1/ws
EXPO_PUBLIC_WS_URL=

# Branding and Organization Config
EXPO_PUBLIC_APP_NAME="CivicLens Mobile"
EXPO_PUBLIC_APP_VERSION="1.0.0"
EXPO_PUBLIC_ORG_NAME="Municipal Corporation"
EXPO_PUBLIC_ORG_SHORT_NAME="MC"
EXPO_PUBLIC_SUPPORT_EMAIL="support@civiclens.space"
EXPO_PUBLIC_ORG_WEBSITE_URL="https://civiclens.space"
EXPO_PUBLIC_SUPPORT_PHONE="1800-CIVIC-LENS"
EXPO_PUBLIC_REPORT_PREFIX="CL"
EXPO_PUBLIC_CITY_CODE="MC"

# Support & Help Headings
EXPO_PUBLIC_SUPPORT_SLOGAN="How can we help you?"
EXPO_PUBLIC_SUPPORT_SUBTITLE="Our support team is available to assist you."
EXPO_PUBLIC_FAQ_TITLE="FAQ"
EXPO_PUBLIC_FAQ_DESC="Frequently asked questions"
EXPO_PUBLIC_CONTACT_EMAIL_TITLE="Contact Email"
EXPO_PUBLIC_CALL_CENTER_TITLE="Call Center"
EXPO_PUBLIC_USER_GUIDE_TITLE="User Guide"
EXPO_PUBLIC_USER_GUIDE_DESC="How to use CivicLens"
