# ============================================================
# CivicLens — Final Production Proxy (Domain & SSL)
# ============================================================

{
	email admin@civiclens.space
}

# Explicitly use HTTPS for the domains
https://civiclens.space, https://www.civiclens.space {
	reverse_proxy client:80
	encode gzip
}

https://admin.civiclens.space {
	reverse_proxy admin:3000
	encode gzip
}

https://api.civiclens.space {
	# MinIO media proxy
	@media path /civiclens-media/*
	handle @media {
		reverse_proxy minio:9000
	}

	# API Health (root level)
	@health path /health /health/*
	handle @health {
		reverse_proxy backend:8000
	}

	# All other API requests
	handle {
		reverse_proxy backend:8000
	}

	encode gzip
}
import sites/*
