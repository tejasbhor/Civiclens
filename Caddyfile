# ============================================================
# CivicLens — Debug Proxy (IP-Only Mode)
# ============================================================

{
	# Disable SSL redirects and auto-https for debugging
	auto_https off
}

http://52.55.40.61, http://localhost {
	# API Backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	# API Health check
	handle /health {
		reverse_proxy backend:8000
	}

	# Admin Dashboard
	handle /admin/* {
		reverse_proxy admin:3000
	}

	# MinIO Media Storage
	handle /civiclens-media/* {
		reverse_proxy minio:9000
	}

	# Citizen Portal (React Client)
	handle {
		reverse_proxy client:80
	}

	# Logging for debug
	log {
		output file /data/caddy_debug.log
	}
}
