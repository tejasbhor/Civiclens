# API Configuration
# Local Dev: http://localhost:8000/api/v1
# Production: https://api.civiclens.space/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Environment
VITE_ENV=development

# Feature Flags
VITE_DISABLE_OFFICER_PORTAL=false
VITE_ENABLE_ERROR_TRACKING=false

# Branding and Organization Config
VITE_APP_NAME="CivicLens Citizen"
VITE_ORG_NAME="Municipal Corporation"
VITE_ORG_SHORT_NAME="MC"
VITE_SUPPORT_EMAIL="support@civiclens.space"
VITE_ORG_WEBSITE_URL="https://civiclens.space"
VITE_REPORT_PREFIX="CL"
VITE_CITY_CODE="MC"

# Analytics (Optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
