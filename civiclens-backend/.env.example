# Application
APP_NAME=CivicLens
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DB_USER=civiclens_user
DB_PASSWORD=your_secure_password
DB_NAME=civiclens_db
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://civiclens_user:your_secure_password@localhost:5432/civiclens_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
ADMIN_TOKEN_EXPIRE_HOURS=8

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=civiclens-media
MINIO_USE_SSL=false

# OTP Settings
OTP_EXPIRY_MINUTES=5

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# Rate Limiting (Set to false for easy development)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_OTP_MAX_REQUESTS=3
RATE_LIMIT_OTP_WINDOW_SECONDS=3600
RATE_LIMIT_LOGIN_MAX_REQUESTS=20

# Email/SMTP Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true

# SMS Configuration (Optional)
SMS_PROVIDER=  # twilio, msg91, aws_sns
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=

# Enhanced Security
CSRF_SECRET_KEY=your_csrf_secret
CSRF_TOKEN_EXPIRE_HOURS=24
ADMIN_IP_WHITELIST_ENABLED=false
ADMIN_IP_WHITELIST=
TWO_FA_ENABLED=true
TWO_FA_ISSUER=CivicLens
TWO_FA_REQUIRED_FOR_ROLES=super_admin

# Password Complexity
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# Session & Audit
SESSION_FINGERPRINT_ENABLED=true
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# Organization Branding (customize per deployment)
CITY_CODE=MC
ORG_NAME="Municipal Corporation"
ORG_SHORT_NAME=MC
ORG_SUPPORT_EMAIL=support@example.com
ORG_WEBSITE_URL=https://example.gov.in
REPORT_NUMBER_PREFIX=CL
DEFAULT_TIMEZONE=Asia/Kolkata
APP_BASE_URL=http://localhost:3000
